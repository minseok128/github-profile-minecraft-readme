{
  "name": "github-profile-minecraft-readme",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Render GitHub contribution data as a Minecraft-style Three.js scene and export README-safe assets.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "render": "tsx src/cli.ts",
    "render:sample": "tsx src/cli.ts --sample --emit-html --output-dir profile"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "playwright": "^1.54.2",
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/three": "^0.183.1",
    "esbuild": "^0.27.3",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
